<Window x:Class="Tranzx.iVS4.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Tranzx.iVS4.App.ViewModels"
        xmlns:views="clr-namespace:Tranzx.iVS4.App.Views"
        xmlns:svc="clr-namespace:Tranzx.iVS4.App.Services"
        Title="{DynamicResource App.Title}"
        Width="1280" Height="820"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        FontSize="{DynamicResource RootFontSize}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- TabControl -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ════════════ TOOLBAR (single row, VMS-style) ════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondary}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Title -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sensor mgmt -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sync controls -->
                    <ColumnDefinition Width="Auto"/>  <!-- Record -->
                    <ColumnDefinition Width="*"/>     <!-- Recording status spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- View mode + font + lang -->
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0" Text="Tranzx Vibration PHM System v1.0" FontWeight="Bold"
                           FontSize="{DynamicResource LargeFontSize}"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- ─── Sensor management group ─── -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{DynamicResource Toolbar.AddSensor}"
                            Command="{Binding AddSensorCommand}"
                            Padding="10,5" Margin="0,0,4,0"
                            Background="{DynamicResource AccentBlue}" Foreground="White"/>
                    <Button Content="{DynamicResource Toolbar.RemoveSensor}"
                            Command="{Binding RemoveSelectedSensorCommand}"
                            Padding="10,5" Margin="0,0,4,0"
                            Background="{DynamicResource AccentRed}" Foreground="White"/>
                    <TextBlock VerticalAlignment="Center" Margin="6,0,12,0"
                               Foreground="{DynamicResource TextSecondary}">
                        <Run Text="{DynamicResource Toolbar.ActiveChannels}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding ActiveChannelCount, Mode=OneWay}"
                             Foreground="{DynamicResource AccentBlue}" FontWeight="Bold"/>
                        <Run Text=" / 4"/>
                    </TextBlock>
                    <Border Width="1" Background="{DynamicResource BgTertiary}" Margin="0,2,12,2"/>
                </StackPanel>

                <!-- ─── Sync control group ─── -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Toolbar.SyncLabel}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="{DynamicResource Toolbar.StartAll}"
                            Command="{Binding SyncStartAllCommand}"
                            Padding="10,5" Margin="0,0,4,0"
                            Background="{DynamicResource AccentTeal}" Foreground="White"/>
                    <Button Content="{DynamicResource Toolbar.StopAll}"
                            Command="{Binding SyncStopAllCommand}"
                            Padding="10,5" Margin="0,0,4,0"
                            Background="{DynamicResource AccentAmber}" Foreground="White"/>
                    <Border Width="1" Background="{DynamicResource BgTertiary}" Margin="6,2"/>
                </StackPanel>

                <!-- ─── Record group ─── -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleSyncRecordingCommand}"
                            Padding="10,5" Margin="0,0,4,0" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentRed}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="{DynamicResource Toolbar.RecordAll}"/>
                                <Style.Triggers>
                                    <!-- 錄製中（非定時）→ 綠 + 「停止錄製」 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSyncRecording}" Value="True"/>
                                            <Condition Binding="{Binding RecordingCountdownText}" Value=""/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="{DynamicResource AccentTeal}"/>
                                        <Setter Property="Content" Value="{DynamicResource Toolbar.StopRecord}"/>
                                    </MultiDataTrigger>
                                    <!-- 定時錄製中 → 綠 + 倒數 -->
                                    <DataTrigger Binding="{Binding IsTimedRecording}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentTeal}"/>
                                        <Setter Property="Content" Value="{Binding RecordingCountdownText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- ─── Spacer with recording indicator ─── -->
                <Border Grid.Column="4" Background="{DynamicResource BgTertiary}" CornerRadius="4"
                        Margin="12,0" Padding="8,2" VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Visibility="{Binding IsSyncRecording, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentRed}"
                                 VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:0.7"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Foreground="{DynamicResource TextPrimary}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center">
                            <Run Text="REC" Foreground="{DynamicResource AccentRed}" FontWeight="Bold"/>
                            <Run Text="  "/>
                            <Run Text="{Binding RecordingDuration, StringFormat=hh\:mm\:ss, Mode=OneWay}"/>
                            <Run Text="  ·  "/>
                            <Run Text="{Binding RecordedSamples, StringFormat=N0, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource Toolbar.SamplesUnit}"/>
                        </TextBlock>
                        <Button Content="📂" Padding="6,1" Margin="8,0,0,0"
                                Command="{Binding OpenSessionFolderCommand}"/>
                    </StackPanel>
                </Border>

                <!-- ─── Right side: Dashboard / Stats / History / EventLog / Preferences / Language ─── -->
                <!-- 5-8c12：按鈕改成 icon-only 節省空間，文字移到 ToolTip -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenDashboardCommand}"
                            Padding="8,5" Margin="0,0,3,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource Dashboard.Title}">
                        <TextBlock Text="☷" FontSize="16"/>
                    </Button>
                    <Button Command="{Binding OpenAlarmStatsCommand}"
                            Padding="8,5" Margin="0,0,3,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource AlarmStats.Title}">
                        <TextBlock Text="📊" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding OpenVibrationStatsCommand}"
                            Padding="8,5" Margin="0,0,3,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource StatsWin.Title}">
                        <TextBlock Text="📈" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding OpenHistoryAnalysisCommand}"
                            Padding="8,5" Margin="0,0,3,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource HistoryWin.Title}">
                        <TextBlock Text="📂" FontSize="14"/>
                    </Button>
                    <!-- 5-9 (A)：3D 動態回放 -->
                    <Button Command="{Binding OpenMotion3DCommand}"
                            Padding="8,5" Margin="0,0,3,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource Motion3D.Title}">
                        <TextBlock Text="🧊" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding OpenEventLogCommand}"
                            Padding="8,5" Margin="0,0,8,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource EventLog.Title}">
                        <TextBlock Text="⚠" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding OpenPreferencesCommand}"
                            Padding="8,5" Margin="0,0,6,0" MinWidth="34"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource Pref.Title}">
                        <TextBlock Text="⚙" FontSize="14"/>
                    </Button>

                    <ComboBox ItemsSource="{Binding Localization.Languages}"
                              SelectedItem="{Binding Localization.CurrentLanguageOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Width="100" Padding="4,3"
                              ToolTip="{DynamicResource Toolbar.Language}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════ Tab Control + 即時狀態監控面板 ════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：原本的 Tab 區域 -->
            <Grid Grid.Column="0">
            <!-- 空狀態：當 SensorTabs 為空 -->
            <Border Background="{DynamicResource BgPrimary}" Padding="20,40">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveChannelCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🔌" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Status.Ready}"
                               FontSize="{DynamicResource LargeFontSize}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- TabControl，當有 Sensor 才顯示 -->
            <TabControl ItemsSource="{Binding SensorTabs}"
                        SelectedItem="{Binding SelectedSensorTab}"
                        Background="{DynamicResource BgPrimary}"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{Binding Channel.ChannelColor}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{DynamicResource Tab.Sensor}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Channel.Index, Converter={StaticResource ChannelIndexPlus1}, Mode=OneWay}"/>
                            </TextBlock>
                            <Ellipse Width="8" Height="8" Margin="6,0,0,0"
                                     Fill="{Binding Channel.State, Converter={StaticResource StateToColor}}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <views:SensorTabView />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
            </Grid>

            <!-- 右側：即時狀態監控（連線）+ 警告監控（振動/環境）— 5-8c10 -->
            <Border Grid.Column="1" Width="300"
                    Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BgTertiary}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 上半：即時狀態（只放連線事件）-->
                    <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 標題列 -->
                    <Border Grid.Row="0" Background="{DynamicResource BgTertiary}" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔔" FontSize="14" Margin="0,0,6,0"
                                           Foreground="{DynamicResource AccentTeal}"/>
                                <TextBlock Text="{DynamicResource LiveFeed.Title}"
                                           FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="OnClearFeedClick"
                                    Padding="6,2" Background="{DynamicResource BgSecondary}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    BorderThickness="0" FontSize="11"
                                    Content="{DynamicResource LiveFeed.Clear}"
                                    ToolTip="{DynamicResource LiveFeed.ClearTip}"/>
                        </Grid>
                    </Border>
                    <!-- Feed 列表 -->
                    <ListBox Grid.Row="1" x:Name="lstFeed"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6,4,6,0" CornerRadius="4"
                                        Background="{DynamicResource BgPrimary}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="3,0,0,0"
                                        Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                   FontSize="16" Margin="0,0,8,0"
                                                   Foreground="{Binding AccentBrush}"
                                                   VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Source}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TimeText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid> <!-- end of upper panel -->

                <!-- 下半：警告監控（振動 / 水平 / 溫濕度警告）-->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource BgTertiary}"
                            Padding="10,8"
                            BorderBrush="{DynamicResource BgPrimary}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚠" FontSize="14" Margin="0,0,6,0"
                                           Foreground="{DynamicResource AccentAmber}"/>
                                <TextBlock Text="{DynamicResource WarnFeed.Title}"
                                           FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="OnClearWarnFeedClick"
                                    Padding="6,2" Background="{DynamicResource BgSecondary}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    BorderThickness="0" FontSize="11"
                                    Content="{DynamicResource LiveFeed.Clear}"/>
                        </Grid>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="lstWarnFeed"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6,4,6,0" CornerRadius="4"
                                        Background="{DynamicResource BgPrimary}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="3,0,0,0"
                                        Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                   FontSize="16" Margin="0,0,8,0"
                                                   Foreground="{Binding AccentBrush}"
                                                   VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Source}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TimeText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════ Status Bar ════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondary}" Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{DynamicResource SmallFontSize}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Foreground="{DynamicResource TextSecondary}"
                           FontSize="{DynamicResource SmallFontSize}">
                    <Run Text="{Binding ActiveChannelCount, Mode=OneWay}"/>
                    <Run Text=" CH"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
