<Window x:Class="Tranzx.iVS4.App.Views.ChartSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ChartSettings.Title}"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 振動 -->
        <GroupBox Grid.Row="0" Header="{DynamicResource ChartSettings.Section.Vib}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ChartSettings.XSec}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbVibX"
                          Width="160" HorizontalAlignment="Left" Padding="6,3" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ChartSettings.VibY}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbVibY"
                          Width="160" HorizontalAlignment="Left" Padding="6,3"/>
            </Grid>
        </GroupBox>

        <!-- 水平 -->
        <GroupBox Grid.Row="1" Header="{DynamicResource ChartSettings.Section.Tilt}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ChartSettings.XSec}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbTiltX"
                          Width="160" HorizontalAlignment="Left" Padding="6,3" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ChartSettings.TiltY}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbTiltY"
                          Width="160" HorizontalAlignment="Left" Padding="6,3"/>
            </Grid>
        </GroupBox>

        <!-- 溫溼度 -->
        <GroupBox Grid.Row="2" Header="{DynamicResource ChartSettings.Section.Env}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ChartSettings.XSec}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbEnvX"
                          Width="160" HorizontalAlignment="Left" Padding="6,3" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ChartSettings.EnvY}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="txtEnvMin" Width="70" Padding="4,3"
                             FontSize="{DynamicResource SmallFontSize}"/>
                    <TextBlock Text=" ~ " VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox x:Name="txtEnvMax" Width="70" Padding="4,3"
                             FontSize="{DynamicResource SmallFontSize}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 按鈕 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Dialog.Cancel}" Padding="20,5" Margin="0,0,8,0"
                    Click="OnCancelClick" IsCancel="True"/>
            <Button Content="{DynamicResource Pref.Apply}" Padding="20,5"
                    Background="{DynamicResource AccentTeal}" Foreground="White"
                    Click="OnApplyClick" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
