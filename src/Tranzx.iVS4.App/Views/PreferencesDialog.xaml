<Window x:Class="Tranzx.iVS4.App.Views.PreferencesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:Tranzx.iVS4.App.Services"
        Title="{DynamicResource Pref.Title}"
        Width="520" Height="700" MinHeight="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ObjectDataProvider x:Key="GravityModeValues" MethodName="GetValues" ObjectType="{x:Type svc:GravityMode}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="svc:GravityMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="FontScaleValues" MethodName="GetValues" ObjectType="{x:Type svc:FontScale}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="svc:FontScale"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- 可滾動內容 -->
            <RowDefinition Height="Auto"/>   <!-- 固定按鈕列 -->
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="16,16,16,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- 振動顯示 -->
        <GroupBox Grid.Row="0" Header="{DynamicResource Pref.Section.Vibration}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}"
                  Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource Pref.Gravity.Label}"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                <RadioButton x:Name="rbRemoveG" GroupName="Grav"
                             Foreground="{DynamicResource TextPrimary}" Margin="6,2"
                             VerticalContentAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.Gravity.Remove}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.Gravity.RemoveTip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="rbKeepG" GroupName="Grav"
                             Foreground="{DynamicResource TextPrimary}" Margin="6,2"
                             VerticalContentAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.Gravity.Keep}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.Gravity.KeepTip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </GroupBox>

        <!-- 水平角度（DC + LPF） -->
        <GroupBox Grid.Row="1" Header="{DynamicResource Pref.Section.Tilt}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}"
                  Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <!-- 角度顯示模式 -->
                <TextBlock Text="{DynamicResource Pref.TiltMode.Label}"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                <RadioButton x:Name="rbModeIncl" GroupName="TiltMode"
                             Foreground="{DynamicResource TextPrimary}" Margin="6,2"
                             VerticalContentAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.TiltMode.Inclinometer}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.TiltMode.InclinometerTip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="rbModeGrav" GroupName="TiltMode"
                             Foreground="{DynamicResource TextPrimary}" Margin="6,2,6,8"
                             VerticalContentAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.TiltMode.GravityVector}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.TiltMode.GravityVectorTip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </RadioButton>

                <!-- 分隔 -->
                <Border Height="1" Background="{DynamicResource BgTertiary}" Margin="0,4"/>

                <!-- LPF -->
                <CheckBox x:Name="cbLpfEnabled" Margin="6,4,6,4"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.TiltLpf.Enable}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.TiltLpf.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
                <Grid Margin="24,4,6,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.TiltLpf.Tau}"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbLpfTau" Width="120" Padding="6,3"
                              ItemTemplate="{StaticResource SecItemTpl}"
                              IsEnabled="{Binding IsChecked, ElementName=cbLpfEnabled}"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- 顯示 -->
        <GroupBox Grid.Row="2" Header="{DynamicResource Pref.Section.Display}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}"
                  Padding="10,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Toolbar.FontSize}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox Grid.Column="1" x:Name="cmbFont"
                          ItemsSource="{Binding Source={StaticResource FontScaleValues}}"
                          Width="120" HorizontalAlignment="Left" Padding="6,3"/>
            </Grid>
        </GroupBox>

        <!-- 效能調校 -->
        <GroupBox Grid.Row="3" Header="{DynamicResource Pref.Section.Performance}"
                  Foreground="{DynamicResource AccentAmber}"
                  BorderBrush="{DynamicResource BgTertiary}"
                  Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource Pref.Perf.Hint}"
                           FontSize="{DynamicResource SmallFontSize}"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.Perf.RefreshHz}"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbRefreshHz" Width="120" Padding="6,3"
                              ItemTemplate="{StaticResource HzItemTpl}"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.Perf.MaxPoints}"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbMaxPoints" Width="120" Padding="6,3"
                              ItemTemplate="{StaticResource IntItemTpl}"/>
                </Grid>
                <!-- 顯示診斷面板 -->
                <Border Height="1" Background="{DynamicResource BgTertiary}" Margin="0,4"/>
                <CheckBox x:Name="cbShowDiag" Margin="0,4,0,0"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.Diag.Show}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.Diag.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>

                <!-- Alarm 音效 -->
                <Border Height="1" Background="{DynamicResource BgTertiary}" Margin="0,4"/>
                <CheckBox x:Name="cbAlarmSound" Margin="0,4,0,0"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.AlarmSound.Show}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.AlarmSound.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>

                <!-- ❗ Phase 5-8c2：Alarm Toast 視覺通知設定 -->
                <Border Height="1" Background="{DynamicResource BgTertiary}" Margin="0,4"/>
                <CheckBox x:Name="cbAlarmToastEnabled" Margin="0,4,0,0"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.Toast.Enable}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.Toast.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
                <StackPanel Orientation="Horizontal" Margin="22,4,0,0"
                            IsEnabled="{Binding ElementName=cbAlarmToastEnabled, Path=IsChecked}">
                    <CheckBox x:Name="cbToastYellow" Content="{DynamicResource Pref.Toast.Yellow}"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"/>
                    <CheckBox x:Name="cbToastRed" Content="{DynamicResource Pref.Toast.Red}"
                              Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- ❗ Phase 5-8c：自動重連設定 -->
        <GroupBox Grid.Row="4" Header="{DynamicResource Pref.Reconnect.Section}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource Pref.Reconnect.Tip}"
                           FontSize="{DynamicResource SmallFontSize}"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.Reconnect.Attempts}"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbReconnectAttempts" Padding="6,3"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.Reconnect.Interval}"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbReconnectInterval" Padding="6,3"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- ❗ Phase 5-8c8：節能模式（VMS 2.0 風格） -->
        <GroupBox Grid.Row="5" Header="{DynamicResource Pref.PowerSaver.Section}"
                  Foreground="{DynamicResource AccentTeal}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <CheckBox x:Name="cbPowerSaver" Margin="0,0,0,4"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.PowerSaver.Enable}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.PowerSaver.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
                <Grid Margin="22,8,0,0"
                      IsEnabled="{Binding ElementName=cbPowerSaver, Path=IsChecked}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Pref.PowerSaver.IdleMin}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbPowerSaverMin" Padding="6,3"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- ❗ Phase 5-8c10：環境警告（溫度 / 濕度） -->
        <GroupBox Grid.Row="6" Header="{DynamicResource Pref.EnvWarn.Section}"
                  Foreground="{DynamicResource AccentAmber}"
                  BorderBrush="{DynamicResource BgTertiary}" Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <CheckBox x:Name="cbEnvWarn" Margin="0,0,0,4"
                          Foreground="{DynamicResource TextPrimary}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Pref.EnvWarn.Enable}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Pref.EnvWarn.Tip}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
                <Grid Margin="22,8,0,0"
                      IsEnabled="{Binding ElementName=cbEnvWarn, Path=IsChecked}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="🌡 黃燈閾值（≥）"
                               VerticalAlignment="Center" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtTempY" Padding="6,3" Margin="0,0,0,4"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="°C" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="🌡 紅燈閾值（≥）"
                               VerticalAlignment="Center" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtTempR" Padding="6,3" Margin="0,0,0,4"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="°C" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="💧 黃燈閾值（≥）"
                               VerticalAlignment="Center" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtHumY" Padding="6,3" Margin="0,0,0,4"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="%" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="💧 紅燈閾值（≥）"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtHumR" Padding="6,3"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="%" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Grid>
            </StackPanel>
        </GroupBox>
        </Grid>
        </ScrollViewer>

        <!-- 按鈕（永遠固定在底部，不會被遮）-->
        <Border Grid.Row="1" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BgTertiary}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Dialog.Cancel}" Padding="20,5" Margin="0,0,8,0"
                        Click="OnCancelClick" IsCancel="True"/>
                <Button Content="{DynamicResource Pref.Apply}" Padding="20,5"
                        Background="{DynamicResource AccentTeal}" Foreground="White"
                        Click="OnApplyClick" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
