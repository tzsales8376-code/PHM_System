<Window x:Class="Tranzx.iVS4.App.Views.AlarmStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/skiawpf"
        Title="{DynamicResource AlarmStats.Title}"
        Width="1100" Height="720"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <TextBlock Grid.Row="0" Text="{DynamicResource AlarmStats.Title}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource AccentTeal}" Margin="0,0,0,10"/>

        <!-- 篩選器 -->
        <Border Grid.Row="1" Background="{DynamicResource BgSecondary}"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource AlarmStats.Range}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbRange" Width="140" Padding="6,3"
                          SelectionChanged="OnRangeChanged"/>
                <TextBlock Text="{DynamicResource AlarmStats.Folder}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"
                           Margin="20,0,8,0"/>
                <TextBlock x:Name="lblFolder" VerticalAlignment="Center" FontFamily="Consolas"
                           FontSize="11" Foreground="{DynamicResource AccentBlue}"
                           TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                <Button Content="🔄" Padding="8,3" Margin="14,0,0,0"
                        Background="{DynamicResource BgTertiary}"
                        Foreground="{DynamicResource TextPrimary}"
                        Click="OnRefreshClick"
                        ToolTip="{DynamicResource AlarmStats.Refresh}"/>
                <Button Content="📂" Padding="8,3" Margin="4,0,0,0"
                        Background="{DynamicResource BgTertiary}"
                        Foreground="{DynamicResource TextPrimary}"
                        Click="OnOpenFolderClick"/>
            </StackPanel>
        </Border>

        <!-- 主體：左側統計 / 右側圖表 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：統計卡片 + 表格 -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 三色 chip -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1ABC9C" CornerRadius="4"
                            Padding="8" Margin="0,0,4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="lblGreen" Text="0" FontSize="22"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource AlarmStats.Green}"
                                       Foreground="White" FontSize="11" Opacity="0.9"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F39C12" CornerRadius="4"
                            Padding="8" Margin="2,0,2,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="lblYellow" Text="0" FontSize="22"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource AlarmStats.Yellow}"
                                       Foreground="White" FontSize="11" Opacity="0.9"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#E74C3C" CornerRadius="4"
                            Padding="8" Margin="4,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="lblRed" Text="0" FontSize="22"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource AlarmStats.Red}"
                                       Foreground="White" FontSize="11" Opacity="0.9"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Sensor × Key 統計表 -->
                <Border Grid.Row="1" Background="{DynamicResource BgSecondary}"
                        CornerRadius="4" Padding="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource AlarmStats.PerSensor}"
                                   FontWeight="Bold" Margin="0,0,0,6"
                                   Foreground="{DynamicResource AccentTeal}"/>
                        <DataGrid x:Name="gridStats" AutoGenerateColumns="False"
                                  Background="{DynamicResource BgSecondary}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource BgTertiary}"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource AlarmStats.Col.Sensor}"
                                                    Binding="{Binding Sensor}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource AlarmStats.Col.Key}"
                                                    Binding="{Binding Key}" Width="80"/>
                                <DataGridTextColumn Header="Y" Binding="{Binding Yellow}" Width="44"/>
                                <DataGridTextColumn Header="R" Binding="{Binding Red}" Width="44"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 右：日期分布 bar chart -->
            <Border Grid.Column="1" Background="{DynamicResource BgSecondary}"
                    CornerRadius="4" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource AlarmStats.Daily}"
                               FontWeight="Bold" Margin="0,0,0,6"
                               Foreground="{DynamicResource AccentTeal}"/>
                    <oxy:PlotView x:Name="chart" Background="Transparent"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 底部訊息 -->
        <TextBlock Grid.Row="3" x:Name="lblStatus" Margin="0,8,0,0"
                   Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
    </Grid>
</Window>
