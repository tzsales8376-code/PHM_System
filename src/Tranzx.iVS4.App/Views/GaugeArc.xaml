<UserControl x:Class="Tranzx.iVS4.App.Views.GaugeArc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <!-- 240×160 canvas：弧 centerY=100 / radius=70，弧頂 y=30，弧底 y≈135 -->
    <Viewbox Stretch="Uniform">
        <Canvas Width="240" Height="160" Background="Transparent">
            <!-- 灰色 background 弧 -->
            <Path x:Name="arcGray" StrokeThickness="14" Stroke="#252535"
                  StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>

            <!-- 三段彩色弧（綠 / 黃 / 紅）-->
            <Path x:Name="arcGreen"  StrokeThickness="14" Stroke="#1ABC9C"
                  StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
            <Path x:Name="arcYellow" StrokeThickness="14" Stroke="#F39C12"
                  StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
            <Path x:Name="arcRed"    StrokeThickness="14" Stroke="#E74C3C"
                  StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>

            <!-- 指針 -->
            <Line x:Name="needle" Stroke="White" StrokeThickness="3"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Ellipse x:Name="needleBase" Canvas.Left="113" Canvas.Top="93"
                     Width="14" Height="14" Fill="White"/>

            <!-- 中央大數值 -->
            <TextBlock x:Name="lblValue" Canvas.Left="0" Canvas.Top="80" Width="240"
                       TextAlignment="Center"
                       FontSize="28" FontWeight="Bold" Foreground="White"/>
            <!-- 子標籤 -->
            <TextBlock x:Name="lblSub" Canvas.Left="0" Canvas.Top="118" Width="240"
                       TextAlignment="Center"
                       FontSize="13" Foreground="#9090A8"/>
        </Canvas>
    </Viewbox>
</UserControl>
