<Window x:Class="Tranzx.iVS4.App.Views.VibrationStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/skiawpf"
        Title="{DynamicResource StatsWin.Title}"
        Width="1200" Height="700" MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgSecondary}" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊" FontSize="20" Margin="0,0,8,0"
                           Foreground="{DynamicResource AccentTeal}"/>
                <TextBlock Text="{DynamicResource StatsWin.Title}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource AccentTeal}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BgTertiary}" BorderThickness="0,1,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource StatsWin.Window}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbWindowSec" Width="100" Padding="6,3" Margin="0,0,12,0"/>

                <TextBlock Text="{DynamicResource StatsWin.Overlap}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbOverlap" Width="80" Padding="6,3" Margin="0,0,12,0"/>

                <TextBlock x:Name="lblNextIn" VerticalAlignment="Center" Margin="8,0,12,0"
                           Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas"/>

                <Border Width="1" Background="{DynamicResource BgTertiary}" Margin="8,2"/>

                <Button x:Name="btnToggle" Padding="14,5" Margin="8,0,4,0"
                        FontWeight="Bold" Click="OnToggleClick"
                        Background="{DynamicResource AccentTeal}" Foreground="White"
                        Content="{DynamicResource StatsWin.Start}"/>
                <Button Padding="10,5" Margin="0,0,4,0" Click="OnExportNowClick"
                        Background="{DynamicResource BgTertiary}" Foreground="{DynamicResource TextPrimary}"
                        Content="{DynamicResource StatsWin.ExportNow}"
                        ToolTip="{DynamicResource StatsWin.ExportNowTip}"/>
                <Button Padding="10,5" Margin="0,0,4,0" Click="OnClearClick"
                        Background="{DynamicResource BgTertiary}" Foreground="{DynamicResource TextPrimary}"
                        Content="{DynamicResource StatsWin.Clear}"/>
            </StackPanel>
        </Border>

        <!-- ❗ 5-8c8：上 chart 下 grid 分割 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- 趨勢圖表（每個 Sensor 三軸 RMS） -->
            <oxy:PlotView Grid.Row="0" x:Name="trendChart"
                          Background="{DynamicResource BgPrimary}"
                          Margin="6,4,6,0"/>

            <!-- 圖表選項列 -->
            <Border Grid.Row="1" Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BgTertiary}" BorderThickness="0,1,0,1"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource StatsWin.ChartMetric}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cmbChartMetric" Width="120" Padding="6,3"
                              SelectionChanged="OnChartMetricChanged"/>
                    <TextBlock Text="{DynamicResource StatsWin.ChartMaxPoints}" Margin="16,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox x:Name="cmbChartMaxPoints" Width="100" Padding="6,3"
                              SelectionChanged="OnChartMaxPointsChanged"/>
                    <CheckBox x:Name="cbAxisX" Content="X" Margin="16,0,4,0" IsChecked="True"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource AccentRed}"
                              Click="OnAxisToggle"/>
                    <CheckBox x:Name="cbAxisY" Content="Y" Margin="0,0,4,0" IsChecked="True"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource AccentTeal}"
                              Click="OnAxisToggle"/>
                    <CheckBox x:Name="cbAxisZ" Content="Z" Margin="0,0,4,0" IsChecked="True"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource AccentBlue}"
                              Click="OnAxisToggle"/>

                    <Border Width="1" Background="{DynamicResource BgTertiary}" Margin="12,2"/>

                    <!-- Y 軸範圍 -->
                    <TextBlock Text="Y" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}" Margin="4,0,4,0"/>
                    <TextBox x:Name="txtYMin" Width="60" Padding="4,3" Margin="0,0,2,0"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             ToolTip="Y Min"
                             VerticalContentAlignment="Center"
                             KeyDown="OnAxisRangeKeyDown"/>
                    <TextBlock Text="~" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}" Margin="2,0"/>
                    <TextBox x:Name="txtYMax" Width="60" Padding="4,3" Margin="0,0,2,0"
                             Background="{DynamicResource BgPrimary}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BgTertiary}"
                             ToolTip="Y Max"
                             VerticalContentAlignment="Center"
                             KeyDown="OnAxisRangeKeyDown"/>
                    <Button x:Name="btnApplyY" Content="✓" Padding="6,2" Margin="2,0,0,0"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource StatsWin.ApplyAxis}"
                            Click="OnApplyAxisClick"/>
                    <Button x:Name="btnAutoAxis" Content="A" Padding="6,2" Margin="4,0,0,0"
                            Background="{DynamicResource BgTertiary}"
                            Foreground="{DynamicResource TextPrimary}"
                            ToolTip="{DynamicResource StatsWin.AutoAxis}"
                            Click="OnAutoAxisClick"/>

                    <!-- X 時間範圍（最近 N 秒）-->
                    <TextBlock Text="{DynamicResource StatsWin.XSpan}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cmbXSpan" Width="80" Padding="4,3"
                              SelectionChanged="OnXSpanChanged"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" x:Name="dgStats"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  CanUserDeleteRows="False" IsReadOnly="True"
                  Background="{DynamicResource BgPrimary}"
                  Foreground="{DynamicResource TextPrimary}"
                  RowBackground="{DynamicResource BgPrimary}"
                  AlternatingRowBackground="{DynamicResource BgSecondary}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource BgTertiary}"
                  HeadersVisibility="Column"
                  FontFamily="Consolas"
                  FontSize="12"
                  ColumnHeaderHeight="28">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource StatsWin.Col.Time}"
                                        Binding="{Binding TimeText}" Width="160"/>
                    <DataGridTextColumn Header="{DynamicResource StatsWin.Col.Sensor}"
                                        Binding="{Binding SensorName}" Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource StatsWin.Col.Axis}"
                                        Binding="{Binding Axis}" Width="50"/>
                    <DataGridTextColumn Header="N"
                                        Binding="{Binding N}" Width="60"/>
                    <DataGridTextColumn Header="Min (G)"
                                        Binding="{Binding MinText}" Width="80"/>
                    <DataGridTextColumn Header="Max (G)"
                                        Binding="{Binding MaxText}" Width="80"/>
                    <DataGridTextColumn Header="Mean (G)"
                                        Binding="{Binding MeanText}" Width="80"/>
                    <DataGridTextColumn Header="Median (G)"
                                        Binding="{Binding MedianText}" Width="90"/>
                    <DataGridTextColumn Header="StdDev (G)"
                                        Binding="{Binding StdDevText}" Width="90"/>
                    <DataGridTextColumn Header="RMS (G)"
                                        Binding="{Binding RmsText}" Width="80"/>
                    <DataGridTextColumn Header="Peak (G)"
                                        Binding="{Binding PeakText}" Width="80"/>
                    <DataGridTextColumn Header="P-P (G)"
                                        Binding="{Binding PpText}" Width="80"/>
                    <DataGridTextColumn Header="Crest"
                                        Binding="{Binding CrestText}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BgTertiary}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource StatsWin.OutputFolder}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextSecondary}"/>
                <Border Grid.Column="1" Background="{DynamicResource BgPrimary}"
                        CornerRadius="3" Padding="6,4">
                    <TextBlock x:Name="lblFolder" FontFamily="Consolas"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource AccentBlue}"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button Grid.Column="2" Margin="6,0,4,0" Padding="10,4"
                        Click="OnBrowseFolderClick"
                        Background="{DynamicResource BgTertiary}"
                        Foreground="{DynamicResource TextPrimary}"
                        Content="{DynamicResource Dialog.Browse}"/>
                <Button Grid.Column="3" Margin="0,0,4,0" Padding="6,4"
                        Click="OnOpenFolderClick"
                        Background="{DynamicResource BgTertiary}"
                        Foreground="{DynamicResource TextPrimary}"
                        Content="📂"
                        ToolTip="{DynamicResource Channel.OpenFolder}"/>
                <TextBlock Grid.Column="4" x:Name="lblStatus" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}"
                           FontFamily="Consolas"/>
            </Grid>
        </Border>
    </Grid>
</Window>
