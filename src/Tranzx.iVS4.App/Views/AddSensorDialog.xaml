<Window x:Class="Tranzx.iVS4.App.Views.AddSensorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dialog.AddSensor.Title}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Slot index + 顯示名稱 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dialog.SlotIndex}"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSlots}"
                      SelectedItem="{Binding SlotIndex}" Margin="0,0,12,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <!-- 顯示 1-based，但 SelectedItem 仍是 0-based int -->
                        <TextBlock Text="{Binding Converter={StaticResource ChannelIndexPlus1}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Column="2" Text="{DynamicResource Dialog.DisplayName}"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <TextBox Grid.Column="3" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- COM Port -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dialog.ComPort}"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableUsbDevices}"
                      SelectedItem="{Binding SelectedUsbDevice}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PortName}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" Width="60"/>
                            <TextBlock Text="{Binding FriendlyName}"
                                       Foreground="{DynamicResource TextSecondary}" Margin="6,0,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Foreground="{DynamicResource AccentBlue}" Margin="8,0,0,0">
                                <Run Text="(VID:"/><Run Text="{Binding Vid}"/><Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="🔄" Margin="6,0,0,0" Padding="8,3"
                    ToolTip="{DynamicResource Dialog.RescanTip}"
                    Command="{Binding ScanUsbCommand}"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ScanStatus}" Margin="80,0,0,10"
                   FontSize="{DynamicResource SmallFontSize}"
                   Foreground="{DynamicResource TextSecondary}"/>

        <!-- Sensor ID（給校正配對） -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dialog.SensorId}"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <TextBox Grid.Column="1" Text="{Binding SensorId, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{DynamicResource Dialog.SensorIdTip}"/>
        </Grid>

        <!-- 按鈕列 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Dialog.Cancel}" Padding="20,5" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="{DynamicResource Dialog.Add}" Padding="20,5"
                    Background="{DynamicResource AccentTeal}" Foreground="White"
                    Command="{Binding ConfirmCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
