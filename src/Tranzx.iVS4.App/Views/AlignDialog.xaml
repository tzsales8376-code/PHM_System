<Window x:Class="Tranzx.iVS4.App.Views.AlignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource HistoryWin.Align}"
        Width="600" Height="380" MinWidth="500" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource HistoryWin.Align}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource AccentTeal}"/>
            <TextBlock Text="{DynamicResource HistoryWin.AlignDesc}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="pnlAnchors"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource HistoryWin.AlignReset}"
                    Padding="14,6" Margin="0,0,8,0"
                    Background="{DynamicResource BgTertiary}"
                    Foreground="{DynamicResource TextPrimary}"
                    Click="OnAlignResetClick"/>
            <Button Content="{DynamicResource Dialog.Cancel}"
                    Padding="14,6" Margin="0,0,8,0" IsCancel="True"
                    Background="{DynamicResource BgTertiary}"
                    Foreground="{DynamicResource TextPrimary}"
                    Click="OnCancelClick"/>
            <Button Content="{DynamicResource Pref.Apply}"
                    Padding="14,6" IsDefault="True"
                    Background="{DynamicResource AccentTeal}"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
