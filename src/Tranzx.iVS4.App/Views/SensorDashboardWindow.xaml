<Window x:Class="Tranzx.iVS4.App.Views.SensorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dashboard.Title}"
        Width="1100" Height="700"
        Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard.Title}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource AccentTeal}"/>
            <TextBlock Grid.Column="1" x:Name="lblSummary" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icSensors">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="380" Height="360" Margin="6"
                                Background="{DynamicResource BgSecondary}"
                                CornerRadius="6" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 標題列：Sensor 名 + 連線狀態 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                                 Fill="{Binding Channel.AccentBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Channel.DisplayName}"
                                                   FontWeight="Bold" FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                            Background="{Binding IsConnected, Converter={StaticResource BoolToConnBrush}}">
                                        <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Dashboard.Disconnected}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Dashboard.Connected}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- 三軸 0-P 大字（5-8c10：加振動 ICON）-->
                                <StackPanel Grid.Row="1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock Text="📊" FontSize="14" Margin="0,0,4,0"
                                                   Foreground="{DynamicResource AccentTeal}"/>
                                        <TextBlock Text="{DynamicResource ViewMode.Vibration}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="X" FontSize="13" FontWeight="Bold"
                                                   Foreground="#E74C3C" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Channel.PeakX, StringFormat={}{0:F3}}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding Channel.XAlarmBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="0-P" FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0">
                                            <Run Text="RMS:"/>
                                            <Run Text="{Binding Channel.RmsX, StringFormat={}{0:F3}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Y" FontSize="13" FontWeight="Bold"
                                                   Foreground="#1ABC9C" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Channel.PeakY, StringFormat={}{0:F3}}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding Channel.YAlarmBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="0-P" FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0">
                                            <Run Text="RMS:"/>
                                            <Run Text="{Binding Channel.RmsY, StringFormat={}{0:F3}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Z" FontSize="13" FontWeight="Bold"
                                                   Foreground="#5294E2" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Channel.PeakZ, StringFormat={}{0:F3}}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding Channel.ZAlarmBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="0-P" FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0">
                                            <Run Text="RMS:"/>
                                            <Run Text="{Binding Channel.RmsZ, StringFormat={}{0:F3}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                </StackPanel>

                                <!-- 底部：溫溼度 + 水平角度（5-8c10：放大 + ICON 顯眼）-->
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 溫度 -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🌡" FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#F39C12"/>
                                        <TextBlock Text="{Binding Channel.TemperatureC, StringFormat={}{0:F1}°C}"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{DynamicResource Channel.Temperature}" FontSize="10"
                                                   Opacity="0.7"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <!-- 濕度 -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="💧" FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#5294E2"/>
                                        <TextBlock Text="{Binding Channel.HumidityPercent, StringFormat={}{0:F0}%}"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{DynamicResource Channel.Humidity}" FontSize="10"
                                                   Opacity="0.7"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <!-- 水平角度 -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📐" FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#1ABC9C"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Channel.AngleX, StringFormat={}{0:F1}}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#E74C3C"/>
                                            <TextBlock Text="/" FontSize="14"
                                                       Foreground="{DynamicResource TextSecondary}" Margin="2,0"/>
                                            <TextBlock Text="{Binding Channel.AngleY, StringFormat={}{0:F1}}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#1ABC9C"/>
                                            <TextBlock Text="/" FontSize="14"
                                                       Foreground="{DynamicResource TextSecondary}" Margin="2,0"/>
                                            <TextBlock Text="{Binding Channel.AngleZ, StringFormat={}{0:F1}°}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#5294E2"/>
                                        </StackPanel>
                                        <TextBlock Text="{DynamicResource Channel.Tilt}" FontSize="10"
                                                   Opacity="0.7"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <!-- 警報徽章 -->
                                    <Border Grid.Column="3" CornerRadius="3" Padding="8,4"
                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                            Background="{Binding Channel.WorstAlarmBrush}">
                                        <TextBlock Foreground="White" FontSize="13" FontWeight="Bold"
                                                   Text="{Binding Channel.WorstAlarmText}"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
